import multiprocessing
import time

def stress_cpu():
    while True:
        pass

def stress_ram():
    memory_hog = []  
    try:
        while :
            memory_hog.append(' ' * (100 * 1024 * 1024))
            time.sleep(0.1) 
        

if __name__ == "__main__":
    cpu_count = multiprocessing.cpu_count()
    
    for _ in range(cpu_count):
        p = multiprocessing.Process(target=stress_cpu)
        p.start()
    stress_ram()
